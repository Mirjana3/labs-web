<!DOCTYPE html>
<html lang="hr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Filomovi">
    <link rel="stylesheet" href="style/style.css">
    <link rel="stylesheet" href="style/style_slike.css">
    <title>Najbolji filmovi</title>
    <style>
        .gallery {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            width: 90%;
            max-width: 1200px;
            margin: 0 auto;
        }

        .gallery-item {
            text-decoration: none;
            color: inherit;
        }

        .gallery figure {
            margin: 0;
            text-align: center;
        }

        .gallery img {
            width: 100%;
            height: 220px;
            object-fit: cover;
            border-radius: 10px;
            transition: transform 0.3s ease;
        }

        .gallery img:hover {
            transform: scale(1.03);
        }

        @media (max-width: 900px) {
            .gallery {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 600px) {
            .gallery {
                grid-template-columns: 1fr;
            }

            h1 {
                font-size: 24px;
            }
        }

        .lightbox {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            justify-content: center;
            align-items: center;
            z-index: 999;
        }

        .lightbox img {
            max-width: 90%;
            max-height: 85%;
            border-radius: 10px;
        }

        .lightbox:target {
            display: flex;
        }

        .close {
            position: absolute;
            top: 20px;
            right: 30px;
            font-size: 40px;
            color: white;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <header>
        <div class="header-top">
            <div class="menu-wrapper">
                <input type="checkbox" id="menu-toggle">
                <label for="menu-toggle" class="menu-btn"></label>
                <nav>
                    <ul class="nav-menu">
                        <li class="dropout">
                            <h2 class="nav-toggle" tabindex="0"></h2>
                            <ul class="dropdown-content">
                                <li><a href="index.html">Pocetna</a></li>
                                <li><a href="slike.html">Galerija</a></li>
                                <li><a href="grafikon.html">Grafikoni</a></li>
                                <li><a href="/slike">Slike</a></li>
                            </ul>
                        </li>
                    </ul>
                </nav>
            </div>
            <h1>Najbolji filmovi</h1>
        </div>
    </header>

    <main>
        <h1>Galerija slika</h1>
        <section class="gallery">
            <% images.forEach(image=> { %>
                <a href="#img-<%= image.id %>" class="gallery-item">
                    <figure>
                        <img src="<%= image.url %>" alt="<%= image.title %>">
                        <figcaption>
                            <%= image.title %>
                        </figcaption>
                    </figure>
                </a>

                <div id="img-<%= image.id %>" class="lightbox">
                    <a href="#" class="close">&times;</a>
                    <img src="<%= image.url %>" alt="<%= image.title %>">
                </div>
                <% }); %>
        </section>
    </main>
</body>

</html>